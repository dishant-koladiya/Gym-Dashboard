{
  "name": "gym-dashboard-2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd Gym-Backend && npm run dev",
    "dev:frontend": "cd Gym-Frontend && npm run dev",
    "build": "cd Gym-Backend && npm run build && cd ../Gym-Frontend && npm run build",
    "lint": "cd Gym-Backend && npm run lint && cd ../Gym-Frontend && npm run lint",
    "test": "cd Gym-Backend && npm test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
